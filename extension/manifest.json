{
  "manifest_version": 3,
  "name": "AI Job Agent",
  "version": "1.0.0",
  "description": "Autofills job applications semantically using Gemini/Groq and tracks your applications.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "options_page": "dashboard.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
